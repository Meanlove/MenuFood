<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Indigenous Food & Coffee</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Noto+Sans+Khmer:wght@300;400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0d0d0d; --surface: #1a1a1a; --surface2: #242424;
    --border: rgba(255,255,255,0.08); --accent: #c87d30; --accent2: #f5d9a8;
    --text: #f0ede8; --muted: rgba(240,237,232,0.45); --card-radius: 18px;
    --font-display: 'Playfair Display', serif;
    --font-khmer: 'Noto Sans Khmer', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }
  html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-body); -webkit-font-smoothing: antialiased; overflow: hidden; }
  #app { max-width: 430px; margin: 0 auto; height: 100dvh; display: flex; flex-direction: column; position: relative; overflow: hidden; }

  /* ── HERO ── */
  .hero-slider { flex-shrink: 0; position: relative; width: 100%; height: 220px; overflow: hidden; }
  .slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1s ease; background-size: cover; background-position: center; }
  .slide.active { opacity: 1; }
  .slide-1 { background-image: linear-gradient(to bottom,rgba(10,5,0,0.2) 0%,rgba(10,5,0,0.5) 55%,rgba(13,13,13,1) 100%), url('https://i.ytimg.com/vi/YXD2KlobR7E/sddefault.jpg'); }
  .slide-2 { background-image: linear-gradient(to bottom,rgba(10,5,0,0.2) 0%,rgba(10,5,0,0.5) 55%,rgba(13,13,13,1) 100%), url('https://i.ytimg.com/vi/U4sYnhdxZvo/hq720.jpg'); }
  .slide-3 { background-image: linear-gradient(to bottom,rgba(10,5,0,0.2) 0%,rgba(10,5,0,0.5) 55%,rgba(13,13,13,1) 100%), url('hero.png'); }
  .slide-content { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; padding: 14px 16px 18px; }
  .hero-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .hero-logo { display: flex; align-items: center; gap: 9px; }
  .hero-logo-circle { width: 48px; height: 48px; border-radius: 50%; overflow: hidden; border: 2px solid rgba(255,255,255,0.2); flex-shrink: 0; background: #1a1a1a; }
  .hero-logo-circle img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .hero-logo-text { display: flex; flex-direction: column; }
  .hero-logo-name { font-family: var(--font-display); color: var(--accent2); font-size: 0.82rem; font-weight: 700; line-height: 1.2; }
  .hero-logo-sub { color: rgba(245,217,168,0.5); font-size: 0.62rem; font-weight: 300; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 2px; }
  .cart-fab { background: var(--accent); border: none; border-radius: 24px; color: #1a0e04; font-family: var(--font-body); font-size: 13px; font-weight: 500; padding: 7px 14px; cursor: pointer; display: flex; align-items: center; gap: 7px; transition: opacity 0.15s,transform 0.1s; flex-shrink: 0; }
  .cart-fab:active { transform: scale(0.96); }
  .cart-fab .n { background: rgba(0,0,0,0.2); border-radius: 50%; width: 20px; height: 20px; font-size: 11px; font-weight: 600; display: flex; align-items: center; justify-content: center; }
  .hero-khmer-tag { font-family: var(--font-khmer); color: rgba(245,217,168,0.6); font-size: 0.72rem; font-weight: 300; display: block; margin-bottom: 4px; }
  .hero-title { font-family: var(--font-display); font-size: 1.5rem; font-weight: 900; color: #fff; line-height: 1.2; text-shadow: 0 2px 12px rgba(0,0,0,0.4); }
  .hero-title span { color: var(--accent); }
  .hero-sub { font-family: var(--font-khmer); color: rgba(255,255,255,0.5); font-size: 0.72rem; margin-top: 4px; }
  .hero-dots { position: absolute; bottom: 22px; right: 16px; display: flex; gap: 5px; z-index: 5; }
  .hdot { width: 5px; height: 5px; border-radius: 50%; background: rgba(255,255,255,0.25); cursor: pointer; transition: all 0.3s; }
  .hdot.active { background: var(--accent); width: 16px; border-radius: 3px; }
  .harrow { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 50%; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 5; color: #fff; font-size: 1rem; transition: background 0.2s; user-select: none; }
  .harrow:hover { background: rgba(255,255,255,0.18); }
  .harrow.prev { left: 10px; } .harrow.next { right: 10px; }

  /* ── CATS ── */
  .cats-wrap { flex-shrink: 0; padding: 10px 16px 0; background: var(--bg); }
  .cats { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 10px; scrollbar-width: none; }
  .cats::-webkit-scrollbar { display: none; }
  .cat { background: var(--surface); border: 1px solid var(--border); color: var(--muted); border-radius: 24px; padding: 6px 16px; font-family: var(--font-body); font-size: 13px; cursor: pointer; white-space: nowrap; transition: all 0.15s; flex-shrink: 0; }
  .cat.on { background: var(--accent); border-color: var(--accent); color: #1a0e04; font-weight: 500; }

  /* ── MENU ── */
  .menu-scroll { flex: 1; overflow-y: auto; padding: 8px 16px 100px; scrollbar-width: none; }
  .menu-scroll::-webkit-scrollbar { display: none; }
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .item-card { background: var(--surface); border-radius: var(--card-radius); overflow: hidden; border: 1px solid var(--border); cursor: pointer; transition: transform 0.12s; animation: fadeUp 0.3s ease both; }
  .item-card:active { transform: scale(0.97); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);} }
  .item-card:nth-child(1){animation-delay:0s}.item-card:nth-child(2){animation-delay:.04s}.item-card:nth-child(3){animation-delay:.08s}.item-card:nth-child(4){animation-delay:.12s}.item-card:nth-child(5){animation-delay:.16s}.item-card:nth-child(6){animation-delay:.20s}
  .item-img-wrap { width:100%; height:120px; overflow:hidden; background:var(--surface2); }
  .item-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; transition:transform 0.3s; }
  .item-card:hover .item-img-wrap img { transform:scale(1.05); }
  .item-fallback { width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:42px; }
  .item-body { padding:10px 11px 12px; }
  .item-name { font-family:var(--font-khmer); font-size:12px; font-weight:600; line-height:1.4; color:var(--text); margin-bottom:8px; }
  .item-bottom { display:flex; align-items:center; justify-content:space-between; }
  .item-price { font-size:15px; font-weight:500; color:var(--accent2); font-family:var(--font-display); }
  .add-btn { background:var(--accent); border:none; border-radius:50%; color:#1a0e04; width:30px; height:30px; font-size:20px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:transform 0.1s; flex-shrink:0; }
  .add-btn:active { transform:scale(0.9); }
  .qty-row { display:flex; align-items:center; gap:6px; }
  .qty-row button { background:var(--surface2); border:1px solid var(--border); color:var(--text); border-radius:50%; width:26px; height:26px; font-size:14px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
  .qty-row button:active { background:var(--accent); border-color:var(--accent); }
  .qty-row .num { font-size:13px; font-weight:500; min-width:14px; text-align:center; }

  /* ── PANELS ── */
  .panel { position:absolute; inset:0; background:var(--bg); display:flex; flex-direction:column; transform:translateY(100%); transition:transform 0.32s cubic-bezier(0.4,0,0.2,1); z-index:20; }
  .panel.open { transform:translateY(0); }
  .panel-head { background:var(--surface); padding:16px 20px; display:flex; align-items:center; gap:12px; border-bottom:1px solid var(--border); flex-shrink:0; }
  .panel-head h2 { font-family:var(--font-display); font-size:18px; font-weight:700; color:var(--text); }
  .back-btn { background:var(--surface2); border:1px solid var(--border); color:var(--text); border-radius:50%; width:34px; height:34px; font-size:16px; cursor:pointer; display:flex; align-items:center; justify-content:center; }
  .cart-body { flex:1; overflow-y:auto; padding:12px 16px; scrollbar-width:none; }
  .cart-body::-webkit-scrollbar { display:none; }
  .empty-msg { text-align:center; color:var(--muted); font-size:14px; padding:40px 0; font-family:var(--font-khmer); }
  .ci { display:flex; align-items:center; gap:12px; padding:11px 0; border-bottom:1px solid var(--border); }
  .ci img,.ci .ci-emoji { width:50px; height:50px; border-radius:12px; object-fit:cover; flex-shrink:0; background:var(--surface2); }
  .ci .ci-emoji { display:flex; align-items:center; justify-content:center; font-size:24px; }
  .ci-info { flex:1; }
  .ci-name { font-size:13px; font-weight:500; color:var(--text); font-family:var(--font-khmer); }
  .ci-sub { font-size:12px; color:var(--muted); margin-top:2px; }
  .ci-price { font-size:14px; font-weight:500; color:var(--accent2); white-space:nowrap; }
  .cart-foot { padding:14px 16px; border-top:1px solid var(--border); background:var(--surface); flex-shrink:0; }
  .total-row { display:flex; justify-content:space-between; font-family:var(--font-display); font-size:17px; font-weight:700; color:var(--text); margin-bottom:14px; }
  .total-row span:last-child { color:var(--accent2); }
  .field { width:100%; background:var(--surface2); border:1px solid var(--border); border-radius:12px; padding:11px 14px; font-family:var(--font-body); font-size:14px; color:var(--text); outline:none; margin-bottom:10px; transition:border-color 0.15s; }
  .field:focus { border-color:var(--accent); }
  .field::placeholder { color:var(--muted); }
  .send-btn { width:100%; background:linear-gradient(135deg,#b56820,#e8a045); border:none; border-radius:14px; padding:14px; font-family:var(--font-display); font-size:15px; font-weight:700; color:#1a0e04; cursor:pointer; transition:opacity 0.15s,transform 0.1s; }
  .send-btn:hover { opacity:0.9; } .send-btn:active { transform:scale(0.98); }
  .send-btn:disabled { background:var(--surface2); color:var(--muted); cursor:default; transform:none; }
  .err-msg { color:#ff6b6b; font-size:12px; text-align:center; margin-top:8px; min-height:16px; }

  /* ── SUCCESS ── */
  .success-panel { position:absolute; inset:0; background:#0d0d0d; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; padding:2rem; z-index:30; transform:translateY(100%); transition:transform 0.35s cubic-bezier(0.4,0,0.2,1); }
  .success-panel.open { transform:translateY(0); }
  .sp-glow1 { position:absolute; width:320px; height:320px; border-radius:50%; background:radial-gradient(circle,rgba(200,125,48,0.18) 0%,transparent 70%); top:-80px; right:-80px; pointer-events:none; }
  .sp-glow2 { position:absolute; width:260px; height:260px; border-radius:50%; background:radial-gradient(circle,rgba(200,125,48,0.10) 0%,transparent 70%); bottom:-60px; left:-60px; pointer-events:none; }
  .sp-card { position:relative; z-index:1; background:#1a1a1a; border:1px solid rgba(255,255,255,0.08); border-radius:28px; width:100%; max-width:360px; overflow:hidden; animation:cardIn 0.6s cubic-bezier(0.22,1,0.36,1) both; }
  @keyframes cardIn { from{opacity:0;transform:translateY(30px) scale(0.96);}to{opacity:1;transform:translateY(0) scale(1);} }
  .sp-banner { width:100%; height:110px; background:linear-gradient(135deg,#3a1f0a 0%,#7a4010 40%,#b56820 100%); display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
  .sp-banner-pattern { position:absolute; inset:0; opacity:0.1; background-image:repeating-linear-gradient(45deg,transparent,transparent 10px,rgba(255,255,255,0.3) 10px,rgba(255,255,255,0.3) 11px); }
  .sp-banner-name { font-family:var(--font-display); color:var(--accent2); font-size:1rem; font-weight:700; z-index:1; text-align:center; line-height:1.4; }
  .sp-banner-sub { color:rgba(245,217,168,0.5); font-size:0.62rem; letter-spacing:0.1em; text-transform:uppercase; margin-top:2px; }
  .sp-body { padding:1.25rem 1.5rem 1.25rem; }
  .sp-icon { font-size:2.4rem; display:block; margin-bottom:0.75rem; animation:pop 0.5s 0.3s cubic-bezier(0.34,1.56,0.64,1) both; }
  @keyframes pop { from{opacity:0;transform:scale(0.3) rotate(-20deg);}to{opacity:1;transform:scale(1) rotate(0);} }
  .sp-title { font-family:var(--font-display); font-size:1.3rem; font-weight:900; color:var(--accent2); line-height:1.3; }
  .sp-khmer { font-family:var(--font-khmer); font-size:0.85rem; color:rgba(245,217,168,0.7); font-weight:400; margin-top:4px; }
  .sp-wait { font-family:var(--font-khmer); font-size:0.82rem; color:rgba(255,255,255,0.5); margin-top:4px; }
  .sp-wait strong { color:var(--accent2); font-weight:700; }
  .sp-divider { width:36px; height:2px; background:linear-gradient(90deg,transparent,var(--accent),transparent); margin:0.85rem auto; }
  .sp-receipt { background:#111; border:1px solid rgba(255,255,255,0.07); border-radius:14px; padding:0.85rem 1rem; text-align:left; margin-bottom:1.1rem; }
  .sp-row { display:flex; justify-content:space-between; align-items:center; padding:5px 0; font-size:0.8rem; color:rgba(255,255,255,0.5); border-bottom:1px solid rgba(255,255,255,0.05); }
  .sp-row:last-child { border-bottom:none; }
  .sp-row .lbl { color:rgba(255,255,255,0.3); font-size:0.72rem; }
  .sp-row .val { color:rgba(255,255,255,0.7); font-weight:500; }
  .sp-row .prc { color:var(--accent); font-weight:500; }
  .sp-total { display:flex; justify-content:space-between; align-items:center; padding-top:8px; font-size:0.95rem; font-weight:600; }
  .sp-total .tl { color:rgba(255,255,255,0.35); }
  .sp-total .tp { color:var(--accent2); font-family:var(--font-display); font-size:1.1rem; }
  .sp-btn { width:100%; padding:0.8rem; border-radius:12px; border:none; background:linear-gradient(135deg,#b56820,#e8a045); color:#1a0e04; font-family:var(--font-khmer); font-size:0.88rem; font-weight:600; cursor:pointer; transition:opacity 0.2s,transform 0.15s; }
  .sp-btn:hover { opacity:0.88; } .sp-btn:active { transform:scale(0.97); }
  .sp-footer { margin-top:1rem; font-size:0.65rem; color:rgba(255,255,255,0.18); letter-spacing:0.1em; text-transform:uppercase; position:relative; z-index:1; }

  /* ── REPORT PANEL ── */
  .report-panel { position:absolute; inset:0; background:var(--bg); display:flex; flex-direction:column; transform:translateY(100%); transition:transform 0.32s cubic-bezier(0.4,0,0.2,1); z-index:25; }
  .report-panel.open { transform:translateY(0); }
  .stat-card { background:var(--surface); border-radius:14px; padding:14px; text-align:center; }
  .stat-label { font-size:11px; color:var(--muted); font-family:var(--font-khmer); margin-bottom:6px; }
  .stat-value { font-size:24px; font-weight:700; font-family:var(--font-display); }

  /* ── PIN MODAL ── */
  .pdot { width:12px; height:12px; border-radius:50%; background:var(--border); border:2px solid rgba(255,255,255,0.2); display:inline-block; transition:all 0.15s; }
  .pdot.filled { background:var(--accent); border-color:var(--accent); }
  .pdot.shake { animation: pinShake 0.3s ease; }
  @keyframes pinShake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-6px)} 75%{transform:translateX(6px)} }
  .pin-key { background:var(--surface2); border:1px solid var(--border); border-radius:14px; padding:14px; font-size:1.1rem; font-weight:600; color:var(--text); cursor:pointer; font-family:var(--font-body); transition:all 0.12s; }
  .pin-key:hover { background:rgba(200,125,48,0.15); border-color:var(--accent); }
  .pin-key:active { transform:scale(0.93); background:var(--accent); color:#1a0e04; }
  .pin-cancel { color:var(--muted); font-size:0.9rem; }
  .pin-del { color:var(--muted); }

  /* ── TABS ── */
  .tab-btn { flex:1; border:none; background:transparent; color:var(--muted); border-radius:10px; padding:7px 8px; font-size:12px; font-weight:500; cursor:pointer; font-family:var(--font-khmer); transition:all 0.18s; }
  .tab-active { background:var(--accent) !important; color:#1a0e04 !important; font-weight:600; }
</style>
</head>
<body>
<div id="app">

  <!-- HERO -->
  <div class="hero-slider" id="heroSlider">
    <div class="slide slide-1 active">
      <div class="slide-content">
        <div class="hero-top">
          <div class="hero-logo">
            <div class="hero-logo-circle" onclick="adminTap()"><img src="logo.png" alt="Logo" style="pointer-events:none;"></div>
            <div class="hero-logo-text">
              <span class="hero-logo-name">Indigenous Food</span>
              <span class="hero-logo-name" style="color:var(--accent);">&amp; Coffee</span>
              <span class="hero-logo-sub hero-sub">📍ទួលទំពូង</span>
            </div>
          </div>
          <button class="cart-fab" onclick="openCart()">Cart <span class="n" id="cartCount">0</span></button>
        </div>
        <div class="hero-bottom">
          <span class="hero-khmer-tag">មុខម្ហូប អាហារជនជាតិដើម</span>
          <div class="hero-title">Welcome to<br><span>Indigenous</span> Food</div>
          <div class="hero-sub">ឃ្លានហើយមែនអត់? កម្មង់ឲ្យលឿនហូវ!</div>
        </div>
      </div>
    </div>
    <div class="slide slide-2">
      <div class="slide-content">
        <div class="hero-top">
          <div class="hero-logo">
            <div class="hero-logo-circle" onclick="adminTap()"><img src="logo.png" alt="Logo" style="pointer-events:none;"></div>
            <div class="hero-logo-text">
              <span class="hero-logo-name">Indigenous Food</span>
              <span class="hero-logo-name" style="color:var(--accent);">&amp; Coffee</span>
              <span class="hero-logo-sub hero-sub">📍ទួលទំពូង</span>
            </div>
          </div>
          <button class="cart-fab" onclick="openCart()">Cart <span class="n" id="cartCount2">0</span></button>
        </div>
        <div class="hero-bottom">
          <span class="hero-khmer-tag">ភ្លក្សរសជាតិពិតប្រាកដ</span>
          <div class="hero-title">Fresh &amp;<br><span>Authentic</span> Taste</div>
          <div class="hero-sub">រសជាតិពិតប្រាកដ ដូចស្នេហាគ្រាដំបូងចឹង</div>
        </div>
      </div>
    </div>
    <div class="slide slide-3">
      <div class="slide-content">
        <div class="hero-top">
          <div class="hero-logo">
            <div class="hero-logo-circle" onclick="adminTap()"><img src="logo.png" alt="Logo" style="pointer-events:none;"></div>
            <div class="hero-logo-text">
              <span class="hero-logo-name">Indigenous Food</span>
              <span class="hero-logo-name" style="color:var(--accent);">&amp; Coffee</span>
              <span class="hero-logo-sub hero-sub">📍ទួលទំពូង</span>
            </div>
          </div>
          <button class="cart-fab" onclick="openCart()">Cart <span class="n" id="cartCount3">0</span></button>
        </div>
        <div class="hero-bottom">
          <span class="hero-khmer-tag">ស្រាពាង</span>
          <div class="hero-title">Order Now &amp;<br><span>Enjoy</span> More</div>
          <div class="hero-sub">ស្រាពាងមានរសជាតិឆ្ងាញ់</div>
        </div>
      </div>
    </div>
    <div class="harrow prev" id="hPrev">‹</div>
    <div class="harrow next" id="hNext">›</div>
    <div class="hero-dots">
      <div class="hdot active" data-i="0"></div>
      <div class="hdot" data-i="1"></div>
      <div class="hdot" data-i="2"></div>
    </div>
  </div>

  <!-- CATEGORIES -->
  <div class="cats-wrap">
    <div class="cats">
      <button class="cat on" onclick="filterCat(this,'all')">All</button>
      <button class="cat" onclick="filterCat(this,'janang')">ចាណាង</button>
      <button class="cat" onclick="filterCat(this,'food')">Food</button>
      <button class="cat" onclick="filterCat(this,'rice')">បាយ &amp; មី</button>
      <button class="cat" onclick="filterCat(this,'drink')">ភេសជ្ជៈ</button>
    </div>
  </div>

  <!-- MENU -->
  <div class="menu-scroll">
    <div class="grid" id="menuGrid"></div>
  </div>

  <!-- PIN MODAL (hidden) -->
  <div id="pinOverlay" style="display:none;position:absolute;inset:0;background:rgba(0,0,0,0.8);z-index:40;align-items:center;justify-content:center;backdrop-filter:blur(4px);">

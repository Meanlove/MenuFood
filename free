        <button onclick="confirmReset()" style="background:var(--surface2);border:1px solid var(--border);border-radius:14px;padding:12px 16px;color:var(--muted);font-size:13px;cursor:pointer;font-family:var(--font-body);white-space:nowrap;">🗑 Reset</button>

</div>
<script>
  const TELEGRAM_BOT_TOKEN = "8445527600:AAGVXX3d4Q7dcu_TfwqMzsfYci3oun1fvbY";
  const TELEGRAM_CHAT_ID   = "-1003819324655";
  const CURRENCY = "$";

  const MENU = [
    { id:1, cat:"janang", name:"ចាណាង សាច់ជ្រូក", price:3,    emoji:"🍔", img:"https://i.ytimg.com/vi/YXD2KlobR7E/sddefault.jpg" },
    { id:2, cat:"janang", name:"ចាណាង​ សាច់គោ",   price:3,    emoji:"🌶️", img:"https://i.ytimg.com/vi/YXD2KlobR7E/sddefault.jpg" },
    { id:3, cat:"food",   name:"ឡាបសាច់ជ្រូក",    price:3,    emoji:"🍖", img:"lab.png" },
    { id:4, cat:"food",   name:"សម្លរបុក",    price:3,    emoji:"🍖", img:"somlorbok.png" },
    { id:5, cat:"food",   name:"សាច់ក្រក់",         price:3,    emoji:"🥩", img:"sachkrok.png" },
    { id:10, cat:"food",  name:"បុកល្ងរ",     price:3.00, emoji:"🥭", img:"boklngor.png" },
    { id:8, cat:"drink",  name:"ស្រាពាងជនជាតិដើម",    price:5, emoji:"🥤", img:"srapeang.png" },
    { id:11, cat:"drink",  name:"Ganzberg",      price:0.75, emoji:"☕", img:"ganz.png" },
    { id:11, cat:"drink",  name:"កាហ្វេទឹកកក",      price:0.75, emoji:"☕", img:"coffee2.png" },
  ];

  /* ══════════════════════════════════════
     ALL-TIME HISTORY  (localStorage, never auto-cleared)
  ══════════════════════════════════════ */

  // Key for today's stats
  function todayKey() {
    const d = new Date();
    return `ifcStats_${d.getFullYear()}_${String(d.getMonth()+1).padStart(2,'0')}_${String(d.getDate()).padStart(2,'0')}`;
  }

  // Format date key to readable string
  function fmtDateKey(key) {
    // key = ifcStats_2026_03_17
    const parts = key.replace('ifcStats_','').split('_');
    if (parts.length < 3) return key;
    const d = new Date(+parts[0], +parts[1]-1, +parts[2]);
    return d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'});
  }

  // Load today's stats
  function loadStats() {
    try { return JSON.parse(localStorage.getItem(todayKey())) || {orders:0, revenue:0, items:{}}; }
    catch(e) { return {orders:0, revenue:0, items:{}}; }
  }

  // Save today's stats
  function saveStats(s) {
    try {
      localStorage.setItem(todayKey(), JSON.stringify(s));
      // Track all known day-keys in an index
      let index = getAllDayKeys();
      if (!index.includes(todayKey())) {
        index.push(todayKey());
        localStorage.setItem('ifcHistoryIndex', JSON.stringify(index));
      }
    } catch(e) {}
  }

  // Get all recorded day keys sorted newest first
  function getAllDayKeys() {
    try { return JSON.parse(localStorage.getItem('ifcHistoryIndex')) || []; }
    catch(e) { return []; }
  }

  // Record order into today + history
  function recordOrder(total) {
    const s = loadStats();
    s.orders++;
    s.revenue += total;
    Object.keys(cart).forEach(id => {
      const item = MENU.find(m => m.id === +id);
      if (!item) return;
      s.items[item.name] = (s.items[item.name] || 0) + cart[id];
    });
    saveStats(s);
  }

  function confirmReset() {
    if (!confirm('Reset today\'s stats only?')) return;
    try { localStorage.removeItem(todayKey()); } catch(e) {}
    renderReport();
    showReportMsg('✅ Reset ថ្ងៃនេះរួចហើយ!', '#4ade80');
  }

  /* ══════════════════════════════════════
     REPORT PANEL UI
  ══════════════════════════════════════ */
  let reportTab = 'today'; // 'today' | 'history'

  /* ── ADMIN TAP (3x logo) + PIN ── */
  const ADMIN_PIN = '2026'; // ← ប្តូរ PIN របស់អ្នក
  let pinInput = '', tapCount = 0, tapTimer = null;

  function adminTap() {
    tapCount++;
    clearTimeout(tapTimer);
    tapTimer = setTimeout(() => { tapCount = 0; }, 1500);
    if (tapCount >= 3) { tapCount = 0; showPin(); }
  }

  function showPin() {
    pinInput = '';
    updatePinDots();
    document.getElementById('pinErr').textContent = '';
    document.getElementById('pinOverlay').style.display = 'flex';
  }

  function closePin() {
    pinInput = '';
    document.getElementById('pinOverlay').style.display = 'none';
  }

  function pinPress(d) {
    if (pinInput.length >= 4) return;
    pinInput += d;
    updatePinDots();
    if (pinInput.length === 4) {
      setTimeout(() => {
        if (pinInput === ADMIN_PIN) {
          closePin();
          renderReport();
          document.getElementById('reportPanel').classList.add('open');
        } else {
          document.getElementById('pinErr').textContent = 'PIN មិនត្រឹមត្រូវ! សូមព្យាយាមម្ដងទៀត';
          document.querySelectorAll('.pdot').forEach(d => d.classList.add('shake'));
          setTimeout(() => {
            pinInput = '';
            updatePinDots();
            document.querySelectorAll('.pdot').forEach(d => d.classList.remove('filled','shake'));
          }, 600);
        }
      }, 150);
    }
  }

  function pinDel() {
    pinInput = pinInput.slice(0,-1);
    updatePinDots();
  }

  function updatePinDots() {
    document.querySelectorAll('.pdot').forEach((dot,i) => {
      dot.classList.toggle('filled', i < pinInput.length);
    });
  }

  function openReport()  { showPin(); }
  function closeReport() { document.getElementById('reportPanel').classList.remove('open'); }

  function showReportMsg(msg, color) {
    const el = document.getElementById('reportMsg');
    el.style.color = color || 'var(--accent2)';
    el.textContent = msg;
    setTimeout(() => el.textContent = '', 3000);
  }

  function switchTab(tab) {
    reportTab = tab;
    document.getElementById('tabToday').classList.toggle('tab-active', tab==='today');
    document.getElementById('tabHistory').classList.toggle('tab-active', tab==='history');
    renderReport();
  }

  function renderReport() {
    if (reportTab === 'history') { renderHistory(); return; }

    const s = loadStats();
    const schedTime = localStorage.getItem('ifcReportTime') || '22:00';
    document.getElementById('reportTime').value = schedTime;

    // top item
    let topName = '—', topQty = 0;
    Object.entries(s.items).forEach(([nm,qty]) => { if (qty > topQty) { topQty = qty; topName = nm; } });

    // item rows
    const sorted = Object.entries(s.items).sort((a,b) => b[1]-a[1]);
    let rows = '';
    if (!sorted.length) {
      rows = `<p style="color:var(--muted);font-size:13px;padding:12px 0;font-family:var(--font-khmer);text-align:center;">មិនទាន់មានការបញ្ជាទិញនៅថ្ងៃនេះ</p>`;
    } else {
      sorted.forEach(([nm,qty],i) => {
        const item = MENU.find(m=>m.name===nm);
        const rev  = item ? fmt(item.price*qty) : '';
        const isTop = i===0;
        rows += `
          <div style="display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border);">
            <span style="font-family:var(--font-khmer);font-size:13px;color:${isTop?'var(--accent2)':'var(--text)'};">${isTop?'🏆 ':''}${nm}</span>
            <div style="display:flex;gap:14px;align-items:center;">
              <span style="font-size:12px;color:var(--muted);">×${qty}</span>
              <span style="font-size:13px;font-weight:600;color:var(--accent);min-width:44px;text-align:right;">${rev}</span>
            </div>
          </div>`;
      });
    }

    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US',{weekday:'short',year:'numeric',month:'short',day:'numeric'});

    document.getElementById('reportBody').innerHTML = `
      <p style="font-size:12px;color:var(--muted);margin-bottom:12px;">${dateStr}</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
        <div class="stat-card"><div class="stat-label">ចំនួនការបញ្ជា</div><div class="stat-value" style="color:var(--accent2);">${s.orders}</div></div>
        <div class="stat-card"><div class="stat-label">ចំណូលសរុប</div><div class="stat-value" style="color:var(--accent);">${fmt(s.revenue)}</div></div>
      </div>
      <div style="background:var(--surface);border-radius:12px;padding:11px 14px;display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <span style="font-size:12px;color:var(--muted);font-family:var(--font-khmer);">🏆 លក់ច្រើនជាងគេ</span>
        <span style="font-size:13px;font-weight:600;color:var(--accent2);font-family:var(--font-khmer);">${topName}</span>
      </div>
      <p style="font-size:12px;color:var(--muted);font-family:var(--font-khmer);margin-bottom:4px;">ចំណែកតាមមុខម្ហូប</p>
      <div>${rows}</div>`;

    document.getElementById('schedStatus').textContent = `⏰ Report នឹងផ្ញើ នៅ ${schedTime}`;
  }

  function renderHistory() {
    const keys = getAllDayKeys().slice().sort((a,b) => b.localeCompare(a)); // newest first

    if (!keys.length) {
      document.getElementById('reportBody').innerHTML =
        `<p style="color:var(--muted);font-size:14px;text-align:center;padding:40px 0;font-family:var(--font-khmer);">មិនទាន់មាន history ណាមួយទេ</p>`;
      return;
    }

    // Compute all-time totals
    let allOrders = 0, allRevenue = 0;
    const allItems = {};
    keys.forEach(k => {
      try {
        const s = JSON.parse(localStorage.getItem(k)) || {};
        allOrders += s.orders||0;
        allRevenue += s.revenue||0;
        Object.entries(s.items||{}).forEach(([nm,qty]) => { allItems[nm]=(allItems[nm]||0)+qty; });
      } catch(e){}
    });

    // All-time top item
    let allTop = '—', allTopQty = 0;
    Object.entries(allItems).forEach(([nm,qty]) => { if(qty>allTopQty){allTopQty=qty;allTop=nm;} });

    // Day cards
    let dayCards = '';
    keys.forEach(key => {
      let s = {orders:0, revenue:0, items:{}};
      try { s = JSON.parse(localStorage.getItem(key)) || s; } catch(e){}
      const dateLabel = fmtDateKey(key);
      const isToday = key === todayKey();

      // top item for this day
      let dTop = '—', dTopQty = 0;
      Object.entries(s.items).forEach(([nm,qty]) => { if(qty>dTopQty){dTopQty=qty;dTop=nm;} });

      // item rows for this day
      const dSorted = Object.entries(s.items).sort((a,b)=>b[1]-a[1]);
      let dRows = dSorted.map(([nm,qty]) => {
        const item = MENU.find(m=>m.name===nm);
        const rev = item ? fmt(item.price*qty) : '';
        return `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(255,255,255,0.04);">
          <span style="font-family:var(--font-khmer);font-size:12px;color:rgba(255,255,255,0.6);">• ${nm}</span>
          <div style="display:flex;gap:10px;">
            <span style="font-size:11px;color:var(--muted);">×${qty}</span>
            <span style="font-size:12px;color:var(--accent);">${rev}</span>
          </div>
        </div>`;
      }).join('');

      if (!dRows) dRows = `<p style="font-size:12px;color:var(--muted);padding:4px 0;font-family:var(--font-khmer);">មិនមានទិន្នន័យ</p>`;

      dayCards += `
        <div style="background:var(--surface);border:1px solid ${isToday?'rgba(200,125,48,0.35)':'var(--border)'};border-radius:16px;margin-bottom:12px;overflow:hidden;">
          <!-- Day header -->
          <div style="padding:12px 14px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);cursor:pointer;user-select:none;" onclick="toggleDayCard(this)">
            <div>
              <div style="font-size:13px;font-weight:600;color:${isToday?'var(--accent2)':'var(--text)'};">${isToday?'📅 ':''}${dateLabel}</div>
              <div style="font-size:11px;color:var(--muted);margin-top:2px;font-family:var(--font-khmer);">${s.orders} ការបញ្ជា · ${fmt(s.revenue)}</div>
            </div>
            <span style="color:var(--muted);font-size:14px;transition:transform 0.2s;" class="day-arrow">▼</span>
          </div>
          <!-- Day body (collapsed by default except today) -->
          <div class="day-body" style="padding:10px 14px;${isToday?'':'display:none;'}">
            <div style="display:flex;gap:8px;margin-bottom:10px;">
              <div style="flex:1;background:var(--surface2);border-radius:10px;padding:8px;text-align:center;">
                <div style="font-size:10px;color:var(--muted);font-family:var(--font-khmer);">ការបញ្ជា</div>
                <div style="font-size:18px;font-weight:700;color:var(--accent2);">${s.orders}</div>
              </div>
              <div style="flex:1;background:var(--surface2);border-radius:10px;padding:8px;text-align:center;">
                <div style="font-size:10px;color:var(--muted);font-family:var(--font-khmer);">ចំណូល</div>
                <div style="font-size:18px;font-weight:700;color:var(--accent);">${fmt(s.revenue)}</div>
              </div>
              <div style="flex:1;background:var(--surface2);border-radius:10px;padding:8px;text-align:center;">
                <div style="font-size:10px;color:var(--muted);">🏆 Top</div>
                <div style="font-size:11px;font-weight:600;color:var(--accent2);font-family:var(--font-khmer);margin-top:3px;">${dTop}</div>
              </div>
            </div>
            ${dRows}
          </div>
        </div>`;
    });

    document.getElementById('reportBody').innerHTML = `
      <!-- All-time summary -->
      <div style="background:linear-gradient(135deg,rgba(181,104,32,0.15),rgba(200,125,48,0.08));border:1px solid rgba(200,125,48,0.2);border-radius:16px;padding:14px;margin-bottom:16px;">
        <div style="font-size:11px;color:var(--accent);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:10px;">All-time Summary</div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:8px;">
          <div style="text-align:center;">
            <div style="font-size:10px;color:var(--muted);font-family:var(--font-khmer);">ថ្ងៃ</div>
            <div style="font-size:20px;font-weight:700;color:var(--accent2);">${keys.length}</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:10px;color:var(--muted);font-family:var(--font-khmer);">ការបញ្ជា</div>
            <div style="font-size:20px;font-weight:700;color:var(--accent2);">${allOrders}</div>
          </div>
          <div style="text-align:center;">
            <div style="font-size:10px;color:var(--muted);font-family:var(--font-khmer);">ចំណូល</div>
            <div style="font-size:18px;font-weight:700;color:var(--accent);">${fmt(allRevenue)}</div>
          </div>
        </div>
        <div style="background:rgba(0,0,0,0.2);border-radius:8px;padding:8px 10px;display:flex;justify-content:space-between;">
          <span style="font-size:11px;color:rgba(245,217,168,0.5);font-family:var(--font-khmer);">🏆 All-time Top</span>
          <span style="font-size:12px;font-weight:600;color:var(--accent2);font-family:var(--font-khmer);">${allTop}</span>
        </div>
      </div>
      <!-- Day-by-day list -->
      <p style="font-size:12px;color:var(--muted);font-family:var(--font-khmer);margin-bottom:10px;">ប្រវត្តិតាមថ្ងៃ (${keys.length} ថ្ងៃ)</p>
      ${dayCards}`;
  }

  function toggleDayCard(header) {
    const body = header.nextElementSibling;
    const arrow = header.querySelector('.day-arrow');
    const isOpen = body.style.display !== 'none';
    body.style.display = isOpen ? 'none' : 'block';
    arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  }

  /* ══════════════════════════════════════
     SCHEDULE  (check every minute)
  ══════════════════════════════════════ */
  function saveSchedule() {
    const t = document.getElementById('reportTime').value;
    if (!t) return;
    localStorage.setItem('ifcReportTime', t);
    renderReport();
    showReportMsg(`✅ រក្សាទុករួច! Report នឹងផ្ញើ នៅ ${t}`, 'var(--accent2)');
  }

  function checkSchedule() {
    const schedTime = localStorage.getItem('ifcReportTime') || '22:00';
    const now = new Date();
    const hhmm = now.toTimeString().slice(0,5);
    const lastSent = localStorage.getItem('ifcLastReportSent');
    const todayStr = now.toDateString();
    if (hhmm === schedTime && lastSent !== todayStr) {
      localStorage.setItem('ifcLastReportSent', todayStr);
      sendDailyReport(false);
    }
  }
  setInterval(checkSchedule, 60000);

  /* ══════════════════════════════════════
     SEND REPORT TO TELEGRAM
  ══════════════════════════════════════ */
  async function sendDailyReport(manual) {
    const s = loadStats();
    const now = new Date();
    const dateStr = now.toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'});
    const timeStr = now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});

    // top item
    let topName = '—', topQty = 0;
    Object.entries(s.items).forEach(([nm,qty]) => { if(qty>topQty){topQty=qty;topName=nm;} });

    // item lines
    const sorted = Object.entries(s.items).sort((a,b)=>b[1]-a[1]);
    const itemLines = sorted.length
      ? sorted.map(([nm,qty]) => {
          const item = MENU.find(m=>m.name===nm);
          const rev = item ? fmt(item.price*qty) : '';
          return `  ${nm} : ${qty}x = ${rev}`;
        }).join('\n')
      : '  (មិនទាន់មានការបញ្ជាទិញ)';

    const divider = '─────────────────';
    const msg = [
      `📊 DAILY SALES REPORT`,
      divider,
      `📅 ${dateStr}`,
      `🕒 Time : ${timeStr}`,
      divider,
      `📦 Order Count : ${s.orders}`,
      `💰 Total Sales : ${fmt(s.revenue)}`,
      `🏆 Top Item : ${topName}`,
      divider,
      `🍽 Items Breakdown :`,
      itemLines,
      divider,
      `🏪 Indigenous Food & Coffee`,
    ].join('\n');

    if (manual) {
      const btn = document.querySelector('#reportPanel .send-btn');
      const orig = btn.textContent;
      btn.disabled = true; btn.textContent = 'កំពុងផ្ញើ…';
      try {
        const res = await fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,{
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({chat_id:TELEGRAM_CHAT_ID, text:msg}),
        });
        const data = await res.json();
        showReportMsg(data.ok ? '✅ ផ្ញើទៅ Telegram ដោយជោគជ័យ!' : '❌ Error: '+data.description, data.ok?'#4ade80':'#f87171');
      } catch(e) { showReportMsg('❌ Network error', '#f87171'); }
      btn.disabled=false; btn.textContent=orig;
    } else {
      fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,{
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({chat_id:TELEGRAM_CHAT_ID, text:msg}),
      }).catch(()=>{});
    }
  }

  /* ══════════════════════════════════════
     HERO SLIDER
  ══════════════════════════════════════ */
  let hCur = 0;
  const hSlides = document.querySelectorAll('.slide');
  const hDots   = document.querySelectorAll('.hdot');
  let hTimer;
  function hGo(n) {
    hSlides[hCur].classList.remove('active'); hDots[hCur].classList.remove('active');
    hCur = (n+hSlides.length)%hSlides.length;
    hSlides[hCur].classList.add('active'); hDots[hCur].classList.add('active');
    updateAllBadges();
  }
  function hStart(){ clearInterval(hTimer); hTimer=setInterval(()=>hGo(hCur+1),4500); }
  document.getElementById('hNext').onclick = ()=>{hGo(hCur+1);hStart();};
  document.getElementById('hPrev').onclick = ()=>{hGo(hCur-1);hStart();};
  hDots.forEach(d=>d.onclick=()=>{hGo(+d.dataset.i);hStart();});
  hStart();

  /* ══════════════════════════════════════
     CART
  ══════════════════════════════════════ */
  let cart = {}, activeCat = 'all';
  function fmt(n){ return CURRENCY+n.toFixed(2); }

  function updateAllBadges(){
    const t=Object.values(cart).reduce((a,b)=>a+b,0);
    ['cartCount','cartCount2','cartCount3'].forEach(id=>{
      const el=document.getElementById(id); if(el) el.textContent=t;
    });
  }

  function renderGrid(){
    const grid=document.getElementById('menuGrid');
    const visible=activeCat==='all'?MENU:MENU.filter(i=>i.cat===activeCat);
    grid.innerHTML='';
    visible.forEach(item=>{
      const qty=cart[item.id]||0;
      const card=document.createElement('div');
      card.className='item-card';
      card.innerHTML=`
        <div class="item-img-wrap">
          ${item.img
            ?`<img src="${item.img}" alt="${item.name}" onerror="this.parentElement.innerHTML='<div class=item-fallback>${item.emoji}</div>'">`
            :`<div class="item-fallback">${item.emoji}</div>`}
        </div>
        <div class="item-body">
          <div class="item-name">${item.name}</div>
          <div class="item-bottom">
            <div class="item-price">${fmt(item.price)}</div>
            ${qty===0
              ?`<button class="add-btn" onclick="add(${item.id})">+</button>`
              :`<div class="qty-row">
                  <button onclick="rem(${item.id})">−</button>
                  <span class="num">${qty}</span>
                  <button onclick="add(${item.id})">+</button>
                </div>`}
          </div>
        </div>`;
      grid.appendChild(card);
    });
  }

  function add(id){ cart[id]=(cart[id]||0)+1; updateAllBadges(); renderGrid(); }
  function rem(id){ if(cart[id]>0)cart[id]--; if(!cart[id])delete cart[id]; updateAllBadges(); renderGrid(); }

  function filterCat(btn,cat){
    document.querySelectorAll('.cat').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on'); activeCat=cat; renderGrid();
  }

  function openCart() { document.getElementById('cartPanel').classList.add('open'); renderCart(); }
  function closeCart(){ document.getElementById('cartPanel').classList.remove('open'); }

  function renderCart(){
    const body=document.getElementById('cartBody');
    const keys=Object.keys(cart);
    if(!keys.length){
      body.innerHTML=`<div class="empty-msg">Your cart is empty 🛒</div>`;
      document.getElementById('cartTotal').textContent=fmt(0); return;
    }
    let total=0; body.innerHTML='';
    keys.forEach(id=>{
      const item=MENU.find(m=>m.id===+id);
      const qty=cart[id]; const sub=item.price*qty; total+=sub;
      const div=document.createElement('div'); div.className='ci';
      div.innerHTML=`
        ${item.img
          ?`<img src="${item.img}" alt="${item.name}" onerror="this.outerHTML='<div class=ci-emoji>${item.emoji}</div>'">`
          :`<div class="ci-emoji">${item.emoji}</div>`}
        <div class="ci-info">
          <div class="ci-name">${item.name}</div>
          <div class="ci-sub">×${qty} × ${fmt(item.price)}</div>
        </div>
        <div class="ci-price">${fmt(sub)}</div>`;
      body.appendChild(div);
    });
    document.getElementById('cartTotal').textContent=fmt(total);
  }

  function buildSuccessReceipt(name,total){
    const now=new Date();
    const timeStr=now.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'})
      +', '+now.toLocaleDateString('en-US',{month:'numeric',day:'numeric',year:'numeric'});
    let html=`
      <div class="sp-row"><span class="lbl">Table</span><span class="val">🪑 ${name}</span></div>
      <div class="sp-row"><span class="lbl">Time</span><span class="val" style="font-size:0.72rem;">${timeStr}</span></div>
      <div class="sp-row" style="padding:6px 0 2px;"><span class="lbl">Items</span><span></span></div>`;
    Object.keys(cart).forEach(id=>{
      const item=MENU.find(m=>m.id===+id);
      html+=`<div class="sp-row"><span style="color:rgba(255,255,255,0.65);">• ${item.name} ×${cart[id]}</span><span class="prc">${fmt(item.price*cart[id])}</span></div>`;
    });
    html+=`<div class="sp-total"><span class="tl">Total</span><span class="tp">${fmt(total)}</span></div>`;
    document.getElementById('spReceipt').innerHTML=html;
  }

  async function placeOrder(){
    const name=document.getElementById('custName').value.trim();
    const err=document.getElementById('errMsg');
    const btn=document.getElementById('sendBtn');
    if(!name){err.textContent='Please enter your name or table number.';return;}
    if(!Object.keys(cart).length){err.textContent='Your cart is empty.';return;}

    const lines=Object.keys(cart).map(id=>{
      const item=MENU.find(m=>m.id===+id);
      return `• ${item.name} x${cart[id]} → ${fmt(item.price*cart[id])}`;
    });
    const total=Object.keys(cart).reduce((acc,id)=>acc+MENU.find(m=>m.id===+id).price*cart[id],0);

    const divider='─────────────────';
    const now=new Date();
    const timeStr=now.toLocaleTimeString()+', '+now.toLocaleDateString();
    const msg=[`🍽 NEW ORDER`,divider,`🪑 Table: ${name}`,`🕐 Time: ${timeStr}`,divider,lines.join('\n'),divider,`💰 Total: ${fmt(total)}`].join('\n');

    btn.disabled=true; btn.textContent='Sending…'; err.textContent='';
    try{
      const res=await fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`,{
        method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({chat_id:TELEGRAM_CHAT_ID,text:msg}),
      });
      const data=await res.json();
      if(data.ok){
        recordOrder(total);            // ← record to daily stats
        buildSuccessReceipt(name,total);
        document.getElementById('successPanel').classList.add('open');
      } else {
        err.textContent='Telegram error: '+(data.description||'Check token & chat ID.');
        btn.disabled=false; btn.textContent='Send order to kitchen →';
      }
    }catch(e){
      err.textContent='Network error. Check your connection.';
      btn.disabled=false; btn.textContent='Send order to kitchen →';
    }
  }

  function resetAll(){
    cart={};
    document.getElementById('successPanel').classList.remove('open');
    document.getElementById('cartPanel').classList.remove('open');
    document.getElementById('custName').value='';
    document.getElementById('errMsg').textContent='';
    document.getElementById('sendBtn').disabled=false;
    document.getElementById('sendBtn').textContent='Send order to kitchen →';
    updateAllBadges(); renderGrid();
  }

  renderGrid();
</script>
</body>
</html>